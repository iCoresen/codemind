# GitHub Token to access PR information and publish comments
GITHUB_TOKEN=your_github_token_here

# DeepSeek API Key for code review
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Optional: needed for webhook payload verification (if using webhook)
GITHUB_WEBHOOK_SECRET=your_secret_here

# AI Model
DEEPSEEK_MODEL=deepseek/deepseek-chat
AI_TIMEOUT=60

# Server configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
LOG_LEVEL=INFO
