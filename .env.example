# GitHub Token to access PR information and publish comments
GITHUB_TOKEN=your_github_token_here

# GitHub Webhook Secret (for payload verification)
GITHUB_WEBHOOK_SECRET=your_secret_here

# DeepSeek API Key for code review
# You can use any provider supported by LiteLLM (OpenAI, Anthropic, Ollama, etc.)
AI_API_KEY=your_api_key_here
AI_BASE_URL=

# AI Model
AI_MODEL=deepseek/deepseek-chat
# Fallback models can be specified as comma-separated list
# Simple format: model1,model2,model3
# Advanced format (JSON dict for per-model config): {"model":"gpt-3.5-turbo","api_base":"https://api.openai.com/v1"},{"model":"claude-3-haiku","api_base":"https://api.anthropic.com"}
AI_FALLBACK_MODELS=
AI_TIMEOUT=60

# Embedding Model Configuration
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=

# Server configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
LOG_LEVEL=INFO

# Redis configuration for Celery and locks
REDIS_URL=redis://localhost:6379/0

# Reviewer Timeout Configuration (in seconds)
# Changelog Reviewer: Fast layer, generate changelog from commits
CHANGELOG_SOFT_TIMEOUT=5.0
CHANGELOG_HARD_TIMEOUT=10.0

# Logic Reviewer: Core layer, security + performance + reducer analysis
LOGIC_SOFT_TIMEOUT=45.0
LOGIC_HARD_TIMEOUT=90.0

# UnitTest Reviewer: Deep layer, generate unit test suggestions
UNITTEST_SOFT_TIMEOUT=45.0
UNITTEST_HARD_TIMEOUT=90.0

# Review Level Configuration
# 1: Fast (Changelog only)
# 2: Standard (Changelog + Logic)
# 3: Deep (Changelog + Logic + UnitTest)
DEFAULT_REVIEW_LEVEL=3

# Core Keywords (comma-separated) - files containing these keywords get higher review priority
CORE_KEYWORDS=auth,payment,database
